# --- Python ---
dashboard/.venv/
**/__pycache__/
*.py[cod]
.env

# --- Node / Quartz build artifacts (regenerated on deploy) ---
wiki-src/node_modules/
wiki-src/public/
wiki-src/.quartz/
wiki-src/.quartz-cache/

# --- Static build output (regenerated by build-static.mjs) ---
dist/

# Exception: the vendored graph plugin ships a prebuilt dist/ that MUST be
# committed. Quartz symlinks local plugin sources without rebuilding them, so
# the deploy relies on this checked-in output.
!wiki-src/plugins/graph/dist/
!wiki-src/plugins/graph/dist/**

# --- Editor / OS ---
.obsidian/workspace*.json
.DS_Store
Thumbs.db

# --- Local tooling state (not needed to run the site) ---
.llm-wiki/
