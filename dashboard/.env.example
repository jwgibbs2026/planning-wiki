# Copy to .env and adjust as needed. All values have sensible defaults.

# Path to the SQLite/SpatiaLite database file (relative to the dashboard/ folder).
PLANNING_DB_PATH=data/planning.sqlite

# Default backfill window (days) on a first import for an authority.
PLANNING_BACKFILL_DAYS=90

# Polite delay (seconds) between PlanIt API page requests.
PLANNING_REQUEST_DELAY=1.0

# Contact string sent in the User-Agent (good scraping etiquette).
PLANNING_USER_AGENT=GlosPlanningWiki/0.1 (private; contact jwgibbs@hotmail.co.uk)

# Phase 3 only — Claude VLM classification (not used in Phase 1).
# ANTHROPIC_API_KEY=
